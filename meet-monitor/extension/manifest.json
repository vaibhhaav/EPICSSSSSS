{
  "manifest_version": 3,
  "name": "Meet Monitor v2",
  "version": "2.0.0",
  "description": "Sentiment monitor for Google Meet",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "tabCapture"
  ],
  "host_permissions": [
    "https://meet.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Monitor"
  }
}
